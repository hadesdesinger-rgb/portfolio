---
import Button from './Button.astro';
import Badge from './Badge.astro';
import { resolvePath } from '../utils/navigation';
---

<section class="relative pt-32 pb-32 lg:pt-18 lg:pb-10 overflow-hidden">
  
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center reveal-on-scroll">
    <div class="flex justify-center mb-8">

    </div>
    
    <h1 class="text-6xl sm:text-7xl lg:text-8xl font-heading font-extrabold tracking-tight text-primary-900 dark:text-white mb-8 max-w-5xl mx-auto leading-[1.1]">
      Si<span class="text-gradient"> Diseñador</span>
    </h1>
    
    <p class="text-xl sm:text-2xl text-primary-600 dark:text-primary-400 mb-12 max-w-3xl mx-auto font-sans leading-relaxed">
      Si
    </p>
    
    <div class="relative mx-auto max-w-6xl reveal-on-scroll" style="transition-delay: 200ms;">
      <div class="aspect-[16/9] rounded-3xl bg-primary-900 dark:bg-[#111111] shadow-2xl border border-primary-800 dark:border-primary-800/80 flex items-center justify-center overflow-hidden relative group hover-glow">
        
        <div class="absolute top-4 left-4 flex gap-2 z-20">
          <div class="w-3 h-3 rounded-full bg-primary-500/80"></div>
          <div class="w-3 h-3 rounded-full bg-primary-400/80"></div>
          <div class="w-3 h-3 rounded-full bg-primary-300/80"></div>
        </div>

        <div class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:24px_24px] z-0"></div>
        
        <div class="relative z-10 p-8 rounded-2xl glass-panel text-left w-3/4 max-w-2xl transform transition-transform group-hover:scale-[1.02] duration-500">
          <h2 class="text-2xl font-heading font-bold text-primary-900 dark:text-white mb-4">Dashboard Component</h2>
          <div class="space-y-3">
            <div class="h-4 bg-primary-200 dark:bg-primary-800 rounded w-3/4"></div>
            <div class="h-4 bg-primary-200 dark:bg-primary-800 rounded w-1/2"></div>
            <div class="h-4 bg-primary-200 dark:bg-primary-800 rounded w-5/6"></div>
          </div>
          <div class="mt-8 grid grid-cols-3 gap-4">
            <div class="h-24 bg-primary-100 dark:bg-primary-900/50 rounded-xl"></div>
            <div class="h-24 bg-accent-100 dark:bg-accent-900/50 rounded-xl"></div>
            <div class="h-24 bg-primary-100 dark:bg-primary-800 rounded-xl"></div>
          </div>
        </div>
      </div>
      
      <div class="absolute -top-12 -left-12 -z-10 w-96 h-96 bg-primary-500/30 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-[100px]"></div>
      <div class="absolute -bottom-12 -right-12 -z-10 w-96 h-96 bg-accent-500/30 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-[100px]"></div>
  
  </div>
</section>
