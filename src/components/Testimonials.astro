---
const skills = [
  {
    name: "Astro",
    level: "Avanzado",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>`,
    color: "bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-400"
  },
  {
    name: "React",
    level: "Avanzado",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle></svg>`,
    color: "bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-400"
  },
  {
    name: "Tailwind CSS",
    level: "Avanzado",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>`,
    color: "bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-400"
  },
  {
    name: "Node.js",
    level: "Intermedio",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>`,
    color: "bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-400"
  },
  {
    name: "TypeScript",
    level: "Intermedio",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>`,
    color: "bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-400"
  },
  {
    name: "Git & GitHub",
    level: "Avanzado",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>`,
    color: "bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-400"
  }
];
---

<section id="Habilidades" class="py-32 bg-white dark:bg-[#000000] relative overflow-hidden">
  
  <div class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/3 w-[500px] h-[500px] bg-primary-500/10 dark:bg-primary-500/5 rounded-full blur-[100px] mix-blend-multiply dark:mix-blend-screen pointer-events-none"></div>

  <div class="container mx-auto px-4 sm:px-6 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-20 reveal-on-scroll">
      <h2 class="text-4xl md:text-5xl font-heading font-extrabold text-primary-900 dark:text-white mb-6">Habilidades</h2>
      <p class="text-xl text-primary-600 dark:text-primary-400">
        Tecnologías y herramientas con las que trabajo.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-7xl mx-auto">
      {skills.map((skill, index) => (
        <div class="glass-panel p-8 rounded-3xl flex flex-col h-full hover-glow reveal-on-scroll relative group" style={`transition-delay: ${index * 100}ms;`}>
          <div class={`w-14 h-14 ${skill.color} rounded-2xl flex items-center justify-center mb-6`} set:html={skill.icon} />
          <h3 class="text-2xl font-heading font-bold text-primary-900 dark:text-white mb-2">{skill.name}</h3>
          <p class="text-primary-500 dark:text-primary-400 text-sm font-medium uppercase tracking-wide">{skill.level}</p>
        </div>
      ))}
    </div>
  </div>
</section>
