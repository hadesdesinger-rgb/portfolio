---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Proyectos" description="Mis proyectos y trabajos realizados.">
  <div class="bg-primary-50 dark:bg-[#0c0c0c] border-b border-primary-200 dark:border-primary-800 py-16 md:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-primary-900 dark:text-white mb-4">Mis Proyectos</h1>
      <p class="text-xl text-primary-600 dark:text-primary-400">
        Una selección de proyectos en los que he trabajado.
      </p>
    </div>
  </div>
</BaseLayout>
