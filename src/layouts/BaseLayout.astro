458C807.16,639.458 807.203,639.46 807.245,639.465L822.699,641.032C825.934,641.026 828.204,640.591 829.474,639.419C830.766,638.227 831.854,636.867 832.733,635.328C833.15,634.597 833.79,634.235 834.428,634.37C835.067,634.504 835.614,635.117 835.879,635.992Z"/>
        </g>
    </g>
            </svg>
        </div> 
        <div id="loader-percent">0%</div>
        <div id="loader-bar"><div id="loader-bar-fill"></div></div>
      </div>

    <script is:inline>
      (function () {
        var el = document.getElementById('loader');
        var pEl = document.getElementById('loader-percent');
        var fEl = document.getElementById('loader-bar-fill');
        if (!el || !pEl || !fEl) return;

        el.style.display = 'flex';

        var steps = 80;
        var cur = 0;

        function tick() {
          cur++;
          var t = Math.min(cur / steps, 1);
          var pct = Math.round((1 - Math.pow(1 - t, 3)) * 100);
          pEl.textContent = pct + '%';
          fEl.style.width = pct + '%';

          if (cur < steps) {
            setTimeout(tick, 25);
          } else {
            setTimeout(function () {
              el.classList.add('hidden');
            }, 700);
          }
        }
        tick();
      })();
    </script>

    <div id="page-content">
      <Navbar />
      <main class="flex-grow">
        <slot />
      </main>
      <Footer />
    </div>

    <!-- Global Observer for scroll animations & loader cleanup -->
    <script>
      document.addEventListener('astro:page-load', () => {

        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-revealed');
            }
          });
        }, {
          root: null,
          rootMargin: '0px',
          threshold: 0.1
        });

        document.querySelectorAll('.reveal-on-scroll').forEach(function (el) {
          observer.observe(el);
        });
      });
    </script>

  </body>
</html>
