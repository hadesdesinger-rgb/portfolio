---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_URL } from '../config';

const SITE_DESCRIPTION = 'Portafolio personal de Hades Conejo';
import { resolvePath } from '../utils/navigation';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  modifiedDate?: Date;
  author?: string;
}

const {
  title,
  description = SITE_DESCRIPTION,
  image = '/og-image.png',
  type = 'website',
  publishedDate,
  modifiedDate,
  author,
} = Astro.props;

const siteURL = SITE_URL.endsWith('/') ? SITE_URL : `${SITE_URL}/`;
const canonicalPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonicalURL = new URL(canonicalPath, siteURL).href;
const imageURL = new URL(image, siteURL).href;
const fullTitle = `${title} | ${SITE_TITLE}`;
const robotsContent = 'index, follow';
const structuredData =
  type === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description,
        image: imageURL,
        url: canonicalURL,
        datePublished: publishedDate?.toISOString(),
        dateModified: (modifiedDate ?? publishedDate)?.toISOString(),
        author: author
          ? {
              '@type': 'Person',
              name: author,
            }
          : undefined,
        publisher: {
          '@type': 'Organization',
          name: SITE_TITLE,
          logo: {
            '@type': 'ImageObject',
            url: new URL('/favicon.svg', siteURL).href,
          },
        },
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: SITE_TITLE,
        description,
        url: siteURL,
      };
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={resolvePath('/favicon.svg')} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href={resolvePath('/sitemap.xml')} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:site_name" content={SITE_TITLE} />
    {type === 'article' && publishedDate && (
      <meta property="article:published_time" content={publishedDate.toISOString()} />
    )}
    {type === 'article' && (modifiedDate ?? publishedDate) && (
      <meta property="article:modified_time" content={(modifiedDate ?? publishedDate)?.toISOString()} />
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@hadesdesinger" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    
    <title>{fullTitle}</title>

    <ClientRouter />

    <!-- Dark Mode initialization script to prevent FOUC and preserve theme across routes -->
    <script is:inline data-astro-rerun>
      (() => {
        const getPreferredTheme = () => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
          }
          if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            return 'dark';
          }
          return 'light';
        };

        const applyTheme = (theme, root = document.documentElement) => {
          root.classList.toggle('dark', theme === 'dark');
          window.localStorage.setItem('theme', theme);
        };

        applyTheme(getPreferredTheme());

        if (!window.__hadesThemeBound) {
          window.__hadesThemeBound = true;

          document.addEventListener('astro:before-swap', (event) => {
            const theme = localStorage.getItem('theme') || getPreferredTheme();
            event.newDocument.documentElement.classList.toggle('dark', theme === 'dark');
          });

          document.addEventListener('astro:after-swap', () => {
            applyTheme(localStorage.getItem('theme') || getPreferredTheme());
            var l = document.getElementById('loader');
            if (l) l.classList.add('hidden');
          });

          document.addEventListener('astro:page-load', () => {
            applyTheme(localStorage.getItem('theme') || getPreferredTheme());
          });
        }
      })();
    </script>

    <style>
      #loader {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #fafafa;
        transition: opacity 0.7s ease, visibility 0.7s ease;
      }
      .dark #loader {
        background: #0a0a0a;
      }
      #loader.hidden {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
      }
      #loader-name {
        position: absolute;
        top: 1.5rem;
        left: 2rem;
        font-size: 1rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        color: #171717;
      }
      .dark #loader-name {
        color: #fafafa;
      }
      #loader-label {
        position: absolute;
        top: 1.5rem;
        right: 2rem;
        font-size: 1rem;
        font-weight: 400;
        letter-spacing: 0.03em;
        color: #525252;
      }
      .dark #loader-label {
        color: #a3a3a3;
      }
      #loader-percent {
        font-size: 5rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1;
        color: #171717;
        transition: color 0.13s;
      }
      .dark #loader-percent {
        color: #fafafa;
      }
      #loader-bar {
        margin-top: 1.5rem;
        width: 160px;
        height: 3px;
        border-radius: 2px;
        background: #e5e5e5;
        overflow: hidden;
      }
      .dark #loader-bar {
        background: #262626;
      }
      #loader-bar-fill {
        height: 100%;
        width: 0%;
        border-radius: 2px;
        background: #525252;
      }
      .dark #loader-bar-fill {
        background: #a3a3a3;
      }
      #loader-logo {
        width: 200px;
        margin-bottom: 3rem;
      }
    </style>
  </head>
  <body class="flex flex-col min-h-screen bg-primary-50 text-primary-900 transition-colors duration-300 dark:bg-[#0a0a0a] dark:text-primary-100">
      <div id="loader" style="display:none" aria-hidden="true">
        <div id="loader-name">Hades Conejo</div>
        <div id="loader-label">Portafolio</div>
        <div id="loader-logo">    
